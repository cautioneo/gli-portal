---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Assurance Loyer Impayé (GLI) 2026 : Zéro Franchise | Cautioneo";
const pageDescription = "Protégez votre investissement locatif avec la meilleure Assurance Loyer Impayé (GLI). Indemnisation dès le 1er jour sans carence. Simulation gratuite en 2 min.";
const pageCanonical = "https://cautioneo-gli.com";
const pageNoindex = false;

const faqItems = [
  {
    question: "Qu\'est-ce que la Garantie Loyers Impayés (GLI) ?",
    answer: "La GLI est une assurance souscrite par le propriétaire bailleur qui le protège contre les impayés de loyers et les dégradations locatives. En cas de défaut de paiement du locataire, l\'assureur se substitue et verse les loyers directement au bailleur, généralement dès le premier mois de retard."
  },
  {
    question: "La prime GLI est-elle déductible des impôts ?",
    answer: "Oui, et c\'est l\'un de ses atouts majeurs. Au régime réel d\'imposition, la prime d\'assurance GLI est intégralement déductible des revenus fonciers. Concrètement, pour un propriétaire imposé à 30 %, une prime de 100 € ne vous coûte réellement que 70 €."
  },
  {
    question: "Quels profils de locataires sont acceptés ?",
    answer: "Cautioneo accepte les locataires en CDI (période d\'essai validée), CDD de longue durée, fonctionnaires, retraités et auto-entrepreneurs sous conditions de revenus. Le critère principal est un taux d\'effort inférieur à 33 % (loyer ≤ 1/3 des revenus nets)."
  },
  {
    question: "Combien de temps dure l\'indemnisation en cas d\'impayé ?",
    answer: "Avec l\'offre Premium, vous êtes couvert jusqu\'à 96 000 € d\'impayés sans limite de durée, jusqu\'à la libération effective du logement. Les frais d\'expulsion (avocat, huissier, serrurier) sont également pris en charge."
  },
  {
    question: "Comment souscrire à la GLI Cautioneo ?",
    answer: "La souscription est 100 % en ligne en moins de 5 minutes. Il vous suffit de renseigner le montant du loyer, de télécharger les justificatifs du locataire (avis d\'imposition, fiches de paie), et Cautioneo vous communique un accord en temps réel ainsi que votre prime définitive."
  }
];
---

<Layout title={pageTitle} description={pageDescription} canonical={pageCanonical} noindex={pageNoindex} faqItems={faqItems}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Garantie Loyer Impayé Cautioneo",
    "description": "Assurance loyer impayé (GLI) pour propriétaires bailleurs : zéro franchise, couverture 96 000€, prise en charge juridique totale.",
    "brand": {
      "@type": "Brand",
      "name": "Cautioneo"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "reviewCount": "848",
      "bestRating": "5",
      "worstRating": "1"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Cautioneo GLI",
    "description": "Assurance loyer impayé (GLI) nouvelle génération pour propriétaires bailleurs.",
    "url": "https://cautioneo-gli.com/",
    "logo": "https://cautioneo-gli.com/logo.png",
    "telephone": "+33 9 72 50 40 51",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lille",
      "postalCode": "59000",
      "streetAddress": "165 Avenue de Bretagne",
      "addressCountry": "FR"
    },
    "sameAs": [
      "https://share.google/1GIqfuIovN1OjliaE",
      "https://www.facebook.com/cautioneo",
      "https://www.linkedin.com/company/cautioneo"
    ]
  })} />
  <Fragment set:html={`<!-- Navigation -->
    

    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-grid">
            <div class="hero-content">
                <h1>L'Assurance Loyer Impayé <br><span class="highlight-gold">100% Digitale, sans Carence ni Franchise.</span></h1>
                <p class="hero-subtitle">
                    Sécurisez votre rendement locatif avec la meilleure Assurance Loyer Impayé (GLI) du marché. Indemnisation dès le premier impayé sans délai de carence, prise en charge complète des procédures d'expulsion, le tout à un tarif ultra-compétitif (100% déductible).
                </p>
                <div class="hero-cta-group" style="flex-direction: column; align-items: flex-start; gap: 10px;">
                    <a href="https://caut.io/Ffr6hkV" target="_blank" class="btn btn-accent" style="font-size: 1.1rem; padding: 16px 32px;" title="Souscrire à l'assurance loyer impayé Cautioneo">Calculer ma prime d'assurance</a>
                    <span style="font-size: 0.9rem; opacity: 0.8; font-family: var(--font-main);">✓ Accord immédiat en
                        ligne ✓ Profils locataires flexibles</span>
                </div>
            </div>

            <!-- Visuel illustratif Premium -->
            <div class="hero-visual"
                style="background: white; border-radius: 12px; padding: 30px; color: var(--color-primary); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); position: relative;">
                <div
                    style="position: absolute; top: -15px; right: -15px; background: var(--color-success); color: white; padding: 8px 16px; border-radius: 20px; font-weight: bold; font-size: 0.9rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                    Devis en 2 min
                </div>
                <h3
                    style="font-size: 1.3rem; margin-bottom: 20px; border-bottom: 2px solid var(--color-border); padding-bottom: 10px;">
                    Simulation GLI (Propriétaire)</h3>

                <div style="margin-bottom: 15px;">
                    <label
                        style="display: block; font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 5px;">Montant
                        du loyer cible (CC)</label>
                    <div
                        style="background: var(--color-bg-alt); padding: 12px; border-radius: 6px; border: 1px solid var(--color-border); font-size: 1.1rem; font-weight: 500;">
                        1 200 € / mois
                    </div>
                </div>
                <div style="margin-bottom: 25px;">
                    <label
                        style="display: block; font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 5px;">Prime
                        d'assurance estimée*</label>
                    <div style="color: var(--color-accent); font-size: 1.8rem; font-weight: 800;">
                        À partir de 2,75%
                    </div>
                    <div style="font-size: 0.75rem; color: var(--color-success); margin-top: 5px;">
                        *100% Déductible de vos revenus fonciers
                    </div>
                </div>

                <a href="https://caut.io/Ffr6hkV" target="_blank" class="btn btn-primary" style="width: 100%; display: block; text-align: center;" title="Souscrire à l'assurance loyer impayé Cautioneo">Démarrer la simulation réelle</a>
            </div>
        </div>
    </section>

    <!-- Bandeau de réassurance B2B -->
    <div class="trust-banner">
        <div class="container trust-content">
            <div class="trust-item">
                <span style="color: var(--color-accent); font-size: 1.2rem;">🛡️</span> Couverture par Odealim & SADA Assurance
            </div>
            <div class="trust-item">
                <span style="color: var(--color-accent); font-size: 1.2rem;">⏱️</span> Indemnisation dès le premier impayé
            </div>
            <a class="trust-item" href="https://share.google/1GIqfuIovN1OjliaE" target="_blank" rel="noopener" style="text-decoration: none; color: inherit; display: inline-flex; align-items: center; gap: 6px;">
                <span style="color: var(--color-accent); font-size: 1.2rem;"><i class="fab fa-google" style="color: #FBBC05;"></i></span> Note 4.6/5 sur Google (848 avis)
            </a>
            <div class="trust-item">
                <span style="color: var(--color-accent); font-size: 1.2rem;">⚖️</span> Frais d'expulsion pris en charge
            </div>
        </div>
    </div>

    <!-- Explication du Concept -->
    <section id="garanties" class="concept-section">
        <div class="container">
            <h2>L'Assurance Loyer Impayé Nouvelle Génération</h2>
            <p class="concept-subtitle">
                Nous avons repensé la GLI pour la rendre plus rapide, plus claire et plus protectrice. Protégez votre
                patrimoine immobilier contre tous les aléas locatifs.
            </p>

            <div class="concept-grid">
                <div class="concept-card card-blue">
                    <div class="concept-icon">⏱️</div>
                    <h3>1. Simulation & Accord en 2 min</h3>
                    <p style="font-family: var(--font-main); font-size: 0.95rem; color: var(--color-text-muted);">
                        Finis les allers-retours interminables avec les courtiers classiques. Obtenez votre tarif et
                        l'agrément de votre locataire 100% en ligne.
                    </p>
                </div>

                <div class="concept-card card-gold">
                    <div class="concept-icon">🛡️</div>
                    <h3>2. Protection Intégrale</h3>
                    <p style="font-family: var(--font-main); font-size: 0.95rem; color: var(--color-text-muted);">
                        Nous couvrons jusqu'à 96 000€ d'impayés sans durée limitée, les dégradations jusqu'à 10 000€, et
                        vos frais de procédure (avocats, huissiers).
                    </p>
                </div>

                <div class="concept-card card-green">
                    <div class="concept-icon">📉</div>
                    <h3>3. Zéro Franchise / 100% Déductible</h3>
                    <p style="font-family: var(--font-main); font-size: 0.95rem; color: var(--color-text-muted);">
                        Vous êtes indemnisé dès le premier mois d'impayé constaté. Et bonne nouvelle : votre prime est
                        entièrement déductible de vos revenus fonciers.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== TARIFS SECTION ===== -->
    <section id="tarifs" class="tarifs-section">
        <div class="container">
            <h2>Nos Tarifs &amp; Simulations</h2>
            <p class="concept-subtitle">Une prime transparente, déductible à 100 % de vos revenus fonciers. Pas de franchise, pas de mauvaise surprise.</p>

            <div class="tarifs-grid">
                <!-- Offre Essentielle -->
                <div class="tarif-card">
                    <div class="tarif-badge">Essentielle</div>
                    <div class="tarif-price">2,75 %<span> du loyer CC</span></div>
                    <ul class="tarif-features">
                        <li>✅ Loyers impayés couverts (24 mois max)</li>
                        <li>✅ Charges &amp; taxes incluses</li>
                        <li>✅ Frais de contentieux remboursés</li>
                        <li>✅ Indemnisation dès le 1er impayé</li>
                        <li>⛔ Détériorations immobilières non incluses</li>
                        <li>⛔ Protection juridique basique</li>
                    </ul>
                    <a href="https://caut.io/Ffr6hkV" target="_blank" class="btn btn-outline" style="width:100%;display:block;text-align:center;margin-top:24px;" title="Souscrire à l'assurance loyer impayé Cautioneo">Obtenir ce devis</a>
                </div>

                <!-- Offre Premium -->
                <div class="tarif-card tarif-card--featured">
                    <div class="tarif-badge tarif-badge--accent">Premium ⭐ Recommandé</div>
                    <div class="tarif-price">2,75 %<span> du loyer CC</span></div>
                    <ul class="tarif-features">
                        <li>✅ Loyers impayés couverts (96 000 € max)</li>
                        <li>✅ Charges, taxes &amp; dépôt de garantie</li>
                        <li>✅ Frais d'expulsion &amp; d'avocat pris en charge</li>
                        <li>✅ Dégradations immobilières (10 000 € max)</li>
                        <li>✅ Protection juridique renforcée</li>
                        <li>✅ Locataires en CDI / CDD / Auto-entrepreneur</li>
                    </ul>
                    <a href="https://caut.io/Ffr6hkV" target="_blank" class="btn btn-accent" style="width:100%;display:block;text-align:center;margin-top:24px;" title="Souscrire à l'assurance loyer impayé Cautioneo">Calculer ma prime</a>
                </div>

                <!-- Offre Agences -->
                <div class="tarif-card">
                    <div class="tarif-badge">Agences &amp; Syndics</div>
                    <div class="tarif-price">Sur mesure</div>
                    <ul class="tarif-features">
                        <li>✅ Tarif négocié au volume</li>
                        <li>✅ Dashboard de suivi centralisé</li>
                        <li>✅ API d'intégration à vos logiciels</li>
                        <li>✅ Gestionnaire de compte dédié</li>
                        <li>✅ Formation équipes incluse</li>
                        <li>✅ SLA de réponse garanti sous 4h</li>
                    </ul>
                    <a href="#agences" class="btn btn-outline" style="width:100%;display:block;text-align:center;margin-top:24px;">Contacter notre équipe</a>
                </div>
            </div>

            <p style="text-align:center;margin-top:32px;font-size:0.85rem;color:var(--color-text-muted);">
                * Prime annuelle exprimée en % du loyer charges comprises. Déductible des revenus fonciers (régime réel). Produit souscrit auprès d'Odealim / SADA Assurance.
            </p>
        </div>
    </section>

    <!-- ===== AGENCES SECTION ===== -->
    <section id="agences" class="agences-section">
        <div class="container">
            <div class="agences-inner">
                <div class="agences-text">
                    <span class="agences-eyebrow">Espace Partenaires</span>
                    <h2>Agences Immobilières &amp; Administrateurs de Biens</h2>
                    <p>Intégrez la GLI Cautioneo directement dans vos mandats de gestion. Offrez à vos bailleurs une protection premium sans friction, et bénéficiez d'une commission attractive sur chaque souscription.</p>

                    <ul class="agences-avantages">
                        <li>
                            <span class="avantage-icon">🏆</span>
                            <div>
                                <strong>Rémunération transparente</strong>
                                <p>Commission fixe sur chaque contrat souscrit via votre lien partenaire, versée mensuellement.</p>
                            </div>
                        </li>
                        <li>
                            <span class="avantage-icon">🔗</span>
                            <div>
                                <strong>Intégration clé en main</strong>
                                <p>API RESTful compatible Apimo, Hektor, Adaptimmo. Connexion en moins d'une journée.</p>
                            </div>
                        </li>
                        <li>
                            <span class="avantage-icon">📊</span>
                            <div>
                                <strong>Dashboard temps réel</strong>
                                <p>Suivez l'état de tous vos contrats, les sinistres en cours et vos commissions en un coup d'œil.</p>
                            </div>
                        </li>
                    </ul>

                    <a href="https://caut.io/Ffr6hkV" target="_blank" class="btn btn-accent" style="margin-top:32px;" title="Souscrire à l'assurance loyer impayé Cautioneo">Devenir partenaire Cautioneo</a>
                </div>

                <div class="agences-stats">
                    <div class="stat-box">
                        <div class="stat-number">+2 400</div>
                        <div class="stat-label">Agences partenaires</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-number">98 %</div>
                        <div class="stat-label">Taux de satisfaction bailleurs</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-number">&lt; 30j</div>
                        <div class="stat-label">Délai moyen d'indemnisation</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-number">0 €</div>
                        <div class="stat-label">Franchise sur loyers impayés</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== FAQ HOME ===== -->
    <section class="faq-section">
        <div class="container">
            <h2>Questions fréquentes sur la GLI</h2>
            <p class="faq-subtitle">Tout ce que vous devez savoir sur la Garantie Loyers Impayés Cautioneo.</p>
            <div class="faq-list">
                <details class="faq-item">
                    <summary class="faq-question">Qu'est-ce que la Garantie Loyers Impayés (GLI) ?</summary>
                    <div class="faq-answer"><p>La GLI est une assurance souscrite par le propriétaire bailleur qui le protège contre les impayés de loyers et les dégradations locatives. En cas de défaut de paiement du locataire, l'assureur se substitue et verse les loyers directement au bailleur, généralement dès le premier mois de retard.</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">La prime GLI est-elle déductible des impôts ?</summary>
                    <div class="faq-answer"><p>Oui, et c'est l'un de ses atouts majeurs. Au régime réel d'imposition, la prime d'assurance GLI est intégralement déductible des revenus fonciers. Concrètement, pour un propriétaire imposé à 30 %, une prime de 100 € ne vous coûte réellement que 70 €.</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Quels profils de locataires sont acceptés ?</summary>
                    <div class="faq-answer"><p>Cautioneo accepte les locataires en CDI (période d'essai validée), CDD de longue durée, fonctionnaires, retraités et auto-entrepreneurs sous conditions de revenus. Le critère principal est un taux d'effort inférieur à 33 % (loyer ≤ 1/3 des revenus nets).</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Combien de temps dure l'indemnisation en cas d'impayé ?</summary>
                    <div class="faq-answer"><p>Avec l'offre Premium, vous êtes couvert jusqu'à 96 000 € d'impayés sans limite de durée, jusqu'à la libération effective du logement. Les frais d'expulsion (avocat, huissier, serrurier) sont également pris en charge.</p></div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Comment souscrire à la GLI Cautioneo ?</summary>
                    <div class="faq-answer"><p>La souscription est 100 % en ligne en moins de 5 minutes. Il vous suffit de renseigner le montant du loyer, de télécharger les justificatifs du locataire (avis d'imposition, fiches de paie), et Cautioneo vous communique un accord en temps réel ainsi que votre prime définitive.</p></div>
                </details>
            </div>
        </div>
    </section>

    <!-- ===== BLOG PREVIEW ===== -->
    <section style="background:var(--color-bg-alt);padding:80px 0;text-align:center;border-top:1px solid var(--color-border);">
        <div class="container">
            <h2 style="font-size:2rem;margin-bottom:12px;">Le Hub du Propriétaire Bailleur</h2>
            <p style="color:var(--color-text-muted);max-width:600px;margin:0 auto 32px;">Conseils juridiques, fiscalité, actualités immobilières — nos experts décryptent pour vous.</p>
            <a href="/blog" class="btn btn-primary" title="Accéder à la page : Blog">Accéder au Blog →</a>
        </div>
    </section>

    


    <script>
        // Mobile nav toggle
        (function() {
            var toggle = document.querySelector('.nav-toggle');
            var navLinks = document.querySelector('.nav-links');
            if (toggle && navLinks) {
                toggle.addEventListener('click', function() {
                    navLinks.classList.toggle('open');
                });
            }
        })();
    </script>`} />
</Layout>
