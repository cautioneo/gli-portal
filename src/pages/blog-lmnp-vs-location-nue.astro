---
import Layout from '../layouts/Layout.astro';

const pageTitle = "LMNP ou Location Nue : Quel Régime Choisir ? | Cautioneo";
const pageDescription = "Découvrez les différences fiscales entre la Location Meublée Non Professionnelle (LMNP) et la location nue. Optimisez vos revenus fonciers en 2026.";
