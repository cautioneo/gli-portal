</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Selectors
    const btnCaseFraud = document.getElementById('btn-case-fraud');
    const btnCaseSuccessMarie = document.getElementById('btn-case-success-marie');
    const btnCaseSuccessJean = document.getElementById('btn-case-success-jean');
    const uploaderInput = document.getElementById('file-uploader');

    const viewPort = document.getElementById('scanner-viewport');
    const promptIdle = document.getElementById('prompt-idle');
    const docMockup = document.getElementById('document-mockup-view');
    const sheetPayroll = document.getElementById('sheet-payroll');
    const sheetTax = document.getElementById('sheet-tax');
    const laserLine = document.getElementById('laser-line');
    
    // Status text label
    const statusLabel = document.getElementById('scanner-status-label');

    // Hotspots
    const hotspotSalary = document.getElementById('hotspot-salary');
    const hotspotLogo = document.getElementById('hotspot-logo');
    const hotspotStamp = document.getElementById('hotspot-stamp');
    const hotspots = [hotspotSalary, hotspotLogo, hotspotStamp];

    // Report
    const reportEmpty = document.getElementById('report-empty');
    const reportData = document.getElementById('report-data');
    const reportScoreCircle = document.getElementById('report-score-circle');
    const reportVerdictBanner = document.getElementById('report-verdict-banner');
    const reportVerdictTitle = document.getElementById('report-verdict-title');
    const reportVerdictBadge = document.getElementById('report-verdict-badge');
    const repInfoCandidate = document.getElementById('rep-info-candidate');
    const repInfoDoc = document.getElementById('rep-info-doc');
    const repChecksList = document.getElementById('report-checks-list-ul');
    const reportInstructions = document.getElementById('report-instructions');

    // Logs Console
    const consoleContainer = document.getElementById('console-logs-container');

    // Sound alert support or log helpers
    function clearLogs() {
      consoleContainer.innerHTML = '';
    }

    function addLog(text, type = 'system-msg') {
      const line = document.createElement('div');
      line.className = `log-line ${type}`;
      line.textContent = `[${new Date().toLocaleTimeString()}] ${text}`;
      consoleContainer.appendChild(line);
      consoleContainer.scrollTop = consoleContainer.scrollHeight;
    }

    // Interactive Scenario Runner
    function runDiagnostic(scenario) {
      // Set active selectors styling
      btnCaseFraud.classList.remove('active');
      btnCaseSuccessMarie.classList.remove('active');
      btnCaseSuccessJean.classList.remove('active');

      if (scenario === 'fraud') btnCaseFraud.classList.add('active');
      if (scenario === 'marie') btnCaseSuccessMarie.classList.add('active');
      if (scenario === 'jean') btnCaseSuccessJean.classList.add('active');

      // Clear report state and show loading
      reportData.style.display = 'none';
      reportEmpty.style.display = 'block';
      reportEmpty.innerHTML = `
        <div class="text-center py-40">
          <i class="fas fa-spinner fa-spin text-primary" style="font-size: 2.5rem;"></i>
          <h3 class="text-md font-bold mt-16 text-main">Analyse AIO en cours...</h3>
          <p class="text-xs text-muted mt-8">Exécution des modèles prédictifs et vérification des bases gouvernementales.</p>
        </div>
      `;

      // Set scanning classes
      viewPort.classList.add('scanning');
      statusLabel.className = 'status-indicator-scanning';
      statusLabel.textContent = 'Analyse en cours...';
      promptIdle.style.display = 'none';
      docMockup.style.display = 'none';
      
      // Hide hotspots
      hotspots.forEach(dot => dot.style.display = 'none');

      clearLogs();
      addLog('Initialisation du moteur de détection de faux documents...', 'system-msg');

      setTimeout(() => {
        // Step 1
        addLog('Fichier chargé avec succès dans le viewport sécurisé.', 'running-msg');
        // Render document type mockups
        docMockup.style.display = 'block';
        if (scenario === 'fraud' || scenario === 'marie') {
          sheetPayroll.style.display = 'block';
          sheetTax.style.display = 'none';
          document.getElementById('mock-tenant-name').textContent = scenario === 'fraud' ? 'Luc BELMONT' : 'Marie DUPONT';
          document.getElementById('mock-net-salary').textContent = scenario === 'fraud' ? '4 200.00 €' : '3 100.00 €';
        } else {
          sheetPayroll.style.display = 'none';
          sheetTax.style.display = 'block';
        }
      }, 600);

      setTimeout(() => {
        // Step 2
        addLog('Extraction OCR et analyse textuelle des caractères...', 'running-msg');
      }, 1200);

      setTimeout(() => {
        // Step 3
        if (scenario === 'fraud') {
          addLog('Alerte : Différence de police détectée sur la ligne "NET A PAYER".', 'alert-msg');
          addLog('Alerte : Anomalie métadonnées - Édition Adobe Photoshop détectée.', 'alert-msg');
        } else {
          addLog('Analyse structurelle et alignement des polices : 100% Cohérent.', 'success-msg');
        }
      }, 1800);

      setTimeout(() => {
        // Step 4
        addLog('Appel API DGFIP pour rapprochement fiscal...', 'running-msg');
      }, 2400);

      setTimeout(() => {
        // Step 5
        if (scenario === 'fraud') {
          addLog('Alerte : Numéro fiscal non concordant ou inexistant.', 'alert-msg');
          addLog('Audit terminé. Score de sécurité critique détecté.', 'alert-msg');
        } else {
          addLog('Rapprochement fiscal : Conforme aux déclarations nationales.', 'success-msg');
          addLog('Audit terminé avec succès. Aucune altération détectée.', 'success-msg');
        }

        // Finish scan
        viewPort.classList.remove('scanning');
        statusLabel.className = 'status-indicator-idle';
        statusLabel.textContent = 'Diagnostic achevé';

        // Render report
        renderReportResult(scenario);
      }, 3200);
    }

    function renderReportResult(scenario) {
      reportEmpty.style.display = 'none';
      reportData.style.display = 'block';

      if (scenario === 'fraud') {
        // Verdict styling
        reportVerdictBanner.className = 'verdict-banner fake mb-24';
        reportScoreCircle.textContent = '12%';
        reportVerdictTitle.textContent = 'Falsification Détectée !';
        reportVerdictBadge.textContent = 'Risque de fraude maximal';

        // Info details
        repInfoCandidate.textContent = 'Luc Belmont';
        repInfoDoc.textContent = 'Bulletin de paie - Mars 2026';
        repInfoStatus.textContent = 'Rejeté par l\'algorithme';

        // Show hotspots on preview
        hotspots.forEach(dot => dot.style.display = 'flex');

        // Checks list
        repChecksList.innerHTML = `
          <li class="check-fail">
            <i class="fas fa-times-circle"></i>
            <span><strong>Intégrité PDF :</strong> Retouche graphique détectée par ELA (Error Level Analysis) sur le salaire net.</span>
          </li>
          <li class="check-fail">
            <i class="fas fa-times-circle"></i>
            <span><strong>Vérification Employeur :</strong> L'entreprise DUMONT SAS a été signalée fermée depuis 2024.</span>
          </li>
          <li class="check-fail">
            <i class="fas fa-times-circle"></i>
            <span><strong>Rapprochement DGFIP :</strong> Les revenus mensuels réels déclarés sont inférieurs à 1 500 € (vs 4 200 € déclarés).</span>
          </li>
        `;
        reportInstructions.style.display = 'flex';

      } else if (scenario === 'marie') {
        // Verdict styling
        reportVerdictBanner.className = 'verdict-banner success mb-24';
        reportScoreCircle.textContent = '100%';
        reportVerdictTitle.textContent = 'Document Conforme';
        reportVerdictBadge.textContent = 'Certifié sans altération';

        // Info details
        repInfoCandidate.textContent = 'Marie Dupont';
        repInfoDoc.textContent = 'Bulletin de paie - Mars 2026';
        repInfoStatus.textContent = 'Certifié Conforme';

        // Checks list
        repChecksList.innerHTML = `
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Intégrité PDF :</strong> Aucun outil d'édition graphique détecté dans les métadonnées de création.</span>
          </li>
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Vérification Employeur :</strong> Société active. Siret et effectifs vérifiés sur base INSEE.</span>
          </li>
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Rapprochement DGFIP :</strong> Rapprochement bancaire et fiscal valide pour 3 100 € nets.</span>
          </li>
        `;
        reportInstructions.style.display = 'none';

      } else if (scenario === 'jean') {
        // Verdict styling
        reportVerdictBanner.className = 'verdict-banner success mb-24';
        reportScoreCircle.textContent = '99%';
        reportVerdictTitle.textContent = 'Avis Fiscal Validé';
        reportVerdictBadge.textContent = 'Authentifié via DGFIP API';

        // Info details
        repInfoCandidate.textContent = 'Jean Petit';
        repInfoDoc.textContent = 'Avis d\'impôt sur le revenu - 2025';
        repInfoStatus.textContent = 'Authenticité confirmée';

        // Checks list
        repChecksList.innerHTML = `
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Validation Numéro Fiscal :</strong> Foyer fiscal trouvé pour Jean Petit, marié, 1 part.</span>
          </li>
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Montant Déclaré :</strong> Le montant de 35 410 € du Revenu Fiscal de Référence est certifié conforme par la DGFIP.</span>
          </li>
          <li class="check-success">
            <i class="fas fa-check-circle"></i>
            <span><strong>Code 2D-Doc / QR-Code :</strong> Signature cryptographique 2D-Doc validée officiellement.</span>
          </li>
        `;
        reportInstructions.style.display = 'none';
      }
    }

    // Trigger demo cases
    btnCaseFraud.addEventListener('click', () => runDiagnostic('fraud'));
    btnCaseSuccessMarie.addEventListener('click', () => runDiagnostic('marie'));
    btnCaseSuccessJean.addEventListener('click', () => runDiagnostic('jean'));

    // Custom File Uploader Mocking
    uploaderInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        // Trigger simulated scan for their custom file
        btnCaseFraud.classList.remove('active');
        btnCaseSuccessMarie.classList.remove('active');
        btnCaseSuccessJean.classList.remove('active');

        reportData.style.display = 'none';
        reportEmpty.style.display = 'block';
        reportEmpty.innerHTML = `
          <div class="text-center py-40">
            <i class="fas fa-spinner fa-spin text-primary" style="font-size: 2.5rem;"></i>
            <h3 class="text-md font-bold mt-16 text-main">Analyse de votre fichier...</h3>
            <p class="text-xs text-muted mt-8">Exécution des modèles prédictifs et vérification des bases gouvernementales.</p>
          </div>
        `;

        viewPort.classList.add('scanning');
        statusLabel.className = 'status-indicator-scanning';
        statusLabel.textContent = 'Analyse en cours...';
        promptIdle.style.display = 'none';
        docMockup.style.display = 'none';
        hotspots.forEach(dot => dot.style.display = 'none');

        clearLogs();
        addLog(`Importation du fichier : ${file.name} (${(file.size / 1024).toFixed(1)} Ko)...`, 'system-msg');
        
        setTimeout(() => {
          addLog('Calcul de l\'empreinte SHA-256 du fichier...', 'running-msg');
        }, 800);

        setTimeout(() => {
          addLog('Analyse OCR : Extraction des textes et identification des blocs...', 'running-msg');
        }, 1600);

        setTimeout(() => {
          addLog('Détection des métadonnées de modification graphique...', 'running-msg');
        }, 2400);

        setTimeout(() => {
          // Finish Custom Scan
          viewPort.classList.remove('scanning');
          statusLabel.className = 'status-indicator-idle';
          statusLabel.textContent = 'Vérification achevée';

          reportEmpty.style.display = 'none';
          reportData.style.display = 'block';

          // Verdict Conforme Standard
          reportVerdictBanner.className = 'verdict-banner success mb-24';
          reportScoreCircle.textContent = '98%';
          reportVerdictTitle.textContent = 'Fichier Conforme';
          reportVerdictBadge.textContent = 'Aucune retouche visible';

          repInfoCandidate.textContent = 'Candidat';
          repInfoDoc.textContent = file.name;
          repInfoStatus.textContent = 'Fichier analysé';

          repChecksList.innerHTML = `
            <li class="check-success">
              <i class="fas fa-check-circle"></i>
              <span><strong>Métadonnées :</strong> Fichier intègre. Aucune trace d'édition graphique majeure détectée.</span>
            </li>
            <li class="check-success">
              <i class="fas fa-check-circle"></i>
              <span><strong>Structure :</strong> La mise en page et les polices correspondent aux standards de l'émetteur.</span>
            </li>
            <li class="check-success">
              <i class="fas fa-info-circle text-primary"></i>
              <span><strong>Validation Cautioneo :</strong> Pour activer la garantie contre les impayés, les originaux seront certifiés officiellement lors du dépôt final du dossier.</span>
            </li>
          `;
          reportInstructions.style.display = 'none';

          addLog('Fichier valide en première lecture. En attente de certification définitive.', 'success-msg');
        }, 3200);
      }
    });

    // Auto-run first scenario on load to show it in action!
    setTimeout(() => {
      runDiagnostic('fraud');
    }, 500);
  });
</script>
