---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Scanner d'Authenticité | Cautioneo Bailleurs";
const pageDescription = "Découvrez notre technologie de détection de faux documents en temps réel. Simulez l'analyse d'un dossier locataire.";
const pageCanonical = "https://cautioneo-gli.com/scanner-demo";
const pageNoindex = true;

const breadcrumbs = [
  { name: "Accueil", item: "https://cautioneo-gli.com/" },
  { name: "Démo Scanner" }
];
---

<Layout title={pageTitle} description={pageDescription} canonical={pageCanonical} noindex={pageNoindex} breadcrumbs={breadcrumbs}>
  <main class="page-content bg-subtle pb-80">
    <header class="hero-mini">
      <div class="container">
        <div class="badge badge-accent mb-16">Intelligence Artificielle AIO</div>
        <h1 class="text-huge mb-16">Scanner d'Authenticité</h1>
        <p class="text-xl opacity-90 max-w-700 mx-auto">
          Testez notre technologie de détection de falsifications. Notre algorithme analyse en temps réel les justificatifs pour écarter les fraudeurs.
        </p>
      </div>
    </header>

    <section class="section-padding">
      <div class="container">
        <div class="scanner-layout">
          <!-- Left: The Scanner Console -->
          <div class="scanner-main-panel">
            <div class="panel-header-custom">
              <h2 class="text-lg font-bold text-main mb-0 flex-between">
                <span><i class="fas fa-microchip text-primary mr-8"></i> Simulateur d'Authentification</span>
                <span class="status-indicator-idle" id="scanner-status-label">Prêt à analyser</span>
              </h2>
            </div>
            
            <div class="scanner-box-wrapper">
              <div class="scanner-box" id="scanner-viewport">
                <!-- Idle state: Upload prompt -->
                <div class="upload-prompt" id="prompt-idle">
                  <div class="prompt-icon">
                    <i class="fas fa-cloud-upload-alt"></i>
                  </div>
                  <h3 class="text-md font-bold mb-8">Glissez-déposez un justificatif de loyer</h3>
                  <p class="text-sm text-muted mb-20">Formats acceptés : PDF, PNG, JPG (Max 5Mo)</p>
                  <span class="btn btn-outline text-sm py-8 px-16">Parcourir les fichiers</span>
                  <input type="file" id="file-uploader" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer;" accept="image/*,application/pdf" />
                </div>

                <!-- Scanning animation overlay -->
                <div class="scan-laser" id="laser-line"></div>

                <!-- Document mock-up preview container -->
                <div class="document-mockup" id="document-mockup-view" style="display: none;">
                  <!-- Payroll Mockup -->
                  <div class="payroll-sheet" id="sheet-payroll">
                    <div class="payroll-header">
                      <div class="company-logo-mock"></div>
                      <div class="company-info-mock">
                        <strong>SOCIETE DUMONT SAS</strong><br/>
                        12 Avenue de Paris, 75001 Paris
                      </div>
                      <div class="payroll-title">BULLETIN DE PAIE</div>
                    </div>
                    <div class="payroll-meta-grid">
                      <div><strong>Période :</strong> Mars 2026</div>
                      <div><strong>N° SS :</strong> 1 85 03 75 120 456</div>
                      <div><strong>Locataire :</strong> <span id="mock-tenant-name">Luc BELMONT</span></div>
                      <div><strong>Emploi :</strong> Cadre Commercial</div>
                    </div>
                    <table class="payroll-table">
                      <thead>
                        <tr>
                          <th>Rubrique</th>
                          <th>Désignation</th>
                          <th>Base</th>
                          <th>Taux</th>
                          <th>Montant</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td>100</td>
                          <td>Salaire de base</td>
                          <td>151.67 h</td>
                          <td>22.50 €</td>
                          <td class="text-right">3 412.58 €</td>
                        </tr>
                        <tr>
                          <td>250</td>
                          <td>Heures supplémentaires</td>
                          <td>10.00 h</td>
                          <td>28.13 €</td>
                          <td class="text-right">281.30 €</td>
                        </tr>
                        <tr class="highlighted-row">
                          <td><strong>900</strong></td>
                          <td><strong>NET A PAYER AVANT IMPOT</strong></td>
                          <td></td>
                          <td></td>
                          <td class="text-right font-bold text-main" id="mock-net-salary">4 200.00 €</td>
                        </tr>
                      </tbody>
                    </table>
                    <div class="payroll-footer">
                      <div class="footer-sign">DUMONT SAS (Signature numérique DGFIP)</div>
                      <div class="footer-stamp">Sceau Certifié AIO</div>
                    </div>
                  </div>

                  <!-- Tax Notice Mockup -->
                  <div class="tax-sheet" id="sheet-tax" style="display: none;">
                    <div class="tax-header">
                      <div>RÉPUBLIQUE FRANÇAISE</div>
                      <div class="tax-title">AVIS D'IMPÔT 2025 SUR LES REVENUS 2024</div>
                    </div>
                    <div class="tax-body">
                      <div class="tax-ref-grid">
                        <div><strong>Foyer Fiscal :</strong> <span id="mock-tax-name">Jean PETIT</span></div>
                        <div><strong>N° Fiscal :</strong> 14 78 520 145 963</div>
                        <div><strong>Adresse :</strong> 4 Rue des Lys, 69002 Lyon</div>
                      </div>
                      <div class="tax-income-box mt-16">
                        <div class="flex-between py-8 border-bottom">
                          <span>Nombre de parts :</span>
                          <strong>1 part</strong>
                        </div>
                        <div class="flex-between py-8 border-bottom">
                          <span>Revenu brut global :</span>
                          <strong>35 410 €</strong>
                        </div>
                        <div class="flex-between py-8 highlighted-row">
                          <span class="font-bold">REVENU FISCAL DE RÉFÉRENCE :</span>
                          <strong class="text-lg text-primary" id="mock-tax-rfr">35 410 €</strong>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Hotspots for Fraud details (Red warning dots) -->
                  <div class="analysis-dot dot-salary" id="hotspot-salary">
                    <span class="pulse-ring"></span>
                    <i class="fas fa-exclamation"></i>
                    <div class="analysis-tooltip">
                      <strong>Anomalie Détectée :</strong><br/>
                      La police de caractères du montant net "4 200.00 €" est incohérente avec le reste du document. Les métadonnées indiquent une retouche graphique récente (Logiciel : Adobe Photoshop).
                    </div>
                  </div>
                  <div class="analysis-dot dot-logo" id="hotspot-logo">
                    <span class="pulse-ring"></span>
                    <i class="fas fa-exclamation"></i>
                    <div class="analysis-tooltip">
                      <strong>Falsification Logo :</strong><br/>
                      Le logo de l'entreprise "DUMONT SAS" a été extrait d'un site web public et inséré par-dessus le fond tramé du PDF.
                    </div>
                  </div>
                  <div class="analysis-dot dot-stamp" id="hotspot-stamp">
                    <span class="pulse-ring"></span>
                    <i class="fas fa-exclamation"></i>
                    <div class="analysis-tooltip">
                      <strong>Incohérence API :</strong><br/>
                      Le code d'authentification et le numéro d'agrément ne correspondent à aucune déclaration légale enregistrée auprès de l'URSSAF.
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Demo Selector Buttons -->
            <div class="demo-selector-bar mt-24">
              <h4 class="text-sm font-bold text-muted uppercase mb-12">Sélectionnez un cas de démonstration :</h4>
              <div class="demo-buttons-grid">
                <button class="btn-demo-selector case-fraud" id="btn-case-fraud">
                  <i class="fas fa-exclamation-triangle"></i>
                  <div>
                    <strong>Faux Dossier (Luc B.)</strong>
                    <span>Bulletin de paie falsifié</span>
                  </div>
                </button>
                <button class="btn-demo-selector case-success" id="btn-case-success-marie">
                  <i class="fas fa-check-circle"></i>
                  <div>
                    <strong>Dossier Conforme (Marie D.)</strong>
                    <span>Bulletin certifié conforme</span>
                  </div>
                </button>
                <button class="btn-demo-selector case-success" id="btn-case-success-jean">
                  <i class="fas fa-check-circle"></i>
                  <div>
                    <strong>Avis d'impôt (Jean P.)</strong>
                    <span>Avis fiscal vérifié DGFIP</span>
                  </div>
                </button>
              </div>
            </div>
          </div>

          <!-- Right: The Scan Report & Console Logs -->
          <div class="scanner-sidebar-panel">
            <!-- Terminal Console Logs (Active while scanning) -->
            <div class="console-box" id="scan-console">
              <div class="console-header">
                <span class="console-dot red"></span>
                <span class="console-dot yellow"></span>
                <span class="console-dot green"></span>
                <span class="console-title">Cautioneo Secure Engine v3.1</span>
              </div>
              <div class="console-body" id="console-logs-container">
                <div class="log-line system-msg">> Console prête. Sélectionnez un scénario pour démarrer l'audit.</div>
              </div>
            </div>

            <!-- Report Results Card (Fills when scan completes) -->
            <div class="report-panel" id="report-result-card">
              <!-- Empty state -->
              <div class="report-empty-state" id="report-empty">
                <i class="fas fa-file-signature text-muted"></i>
                <h3 class="text-md font-bold text-main mt-16">Aucun diagnostic disponible</h3>
                <p class="text-sm text-muted">Lancez une analyse interactive à gauche pour éditer le rapport de sécurité.</p>
              </div>

              <!-- Diagnostic Result -->
              <div class="report-content" id="report-data" style="display: none;">
                <div class="verdict-banner mb-24" id="report-verdict-banner">
                  <div class="verdict-score-circular" id="report-score-circle">12%</div>
                  <div class="verdict-meta">
                    <h3 class="text-lg font-bold mb-4" id="report-verdict-title">Falsification Détectée !</h3>
                    <span class="verdict-badge" id="report-verdict-badge">Niveau de risque maximal</span>
                  </div>
                </div>

                <div class="report-summary-box mb-24">
                  <h4 class="text-sm font-bold uppercase text-muted mb-12">Informations Générales</h4>
                  <div class="summary-details">
                    <div><span>Candidat :</span> <strong id="rep-info-candidate">Luc Belmont</strong></div>
                    <div><span>Document :</span> <strong id="rep-info-doc">Bulletin de paie - Mars 2026</strong></div>
                    <div><span>Vérification :</span> <strong id="rep-info-status">Analysé par AIO Scanner</strong></div>
                  </div>
                </div>

                <div class="report-checks-list mb-24">
                  <h4 class="text-sm font-bold uppercase text-muted mb-12">Points de Contrôle Algorithmiques</h4>
                  <ul class="checks-ul" id="report-checks-list-ul">
                    <!-- Checks injected via JS -->
                  </ul>
                </div>

                <div class="report-instructions-box" id="report-instructions">
                  <i class="fas fa-info-circle text-primary"></i>
                  <p class="text-xs">
                    <strong>Note de l'analyste :</strong> Passez votre curseur sur les pastilles de signalement rouges sur le document pour inspecter les preuves de manipulation.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Banner CTA Bailleurs -->
        <div class="mt-48 p-40 bg-dark text-white border-radius-20 text-center relative-overflow" data-reveal="fade-up">
          <div class="badge badge-accent mb-16">Garantie Loyers Impayés</div>
          <h2 class="text-3xl mb-16 text-white">Sécurisez votre investissement locatif avec Cautioneo</h2>
          <p class="text-lg opacity-80 mb-32 max-w-700 mx-auto">
            Ne risquez plus de louer avec de faux justificatifs. Notre technologie certifie automatiquement vos locataires, et nous couvrons vos loyers jusqu'à 96 000 € sans franchise.
          </p>
          <div class="cta-button-group">
            <a class="btn btn-white mr-16" href="https://caut.io/Ffr6hkV" target="_blank" title="S'inscrire sur Cautioneo">Créer mon Espace Bailleur</a>
            <a class="btn btn-white-outline" href="/comparatif-gli" title="En savoir plus sur nos garanties">Voir les garanties</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Base Layout structures */
  .scanner-layout {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 32px;
    align-items: start;
  }
  
  @media (max-width: 1024px) {
    .scanner-layout {
      grid-template-columns: 1fr;
    }
  }

  .scanner-main-panel, .scanner-sidebar-panel {
    display: flex;
    flex-direction: column;
  }

  .panel-header-custom {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-bottom: none;
    padding: 24px;
    border-radius: 20px 20px 0 0;
    box-shadow: 0 4px 20px -2px rgba(108, 92, 231, 0.03);
  }

  .status-indicator-idle {
    font-size: 0.72rem;
    font-weight: 700;
    color: #64748b;
    background: #f1f5f9;
    padding: 6px 14px;
    border-radius: 50px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
  }
  
  .status-indicator-scanning {
    font-size: 0.72rem;
    font-weight: 700;
    color: #6c5ce7;
    background: rgba(108, 92, 231, 0.1);
    padding: 6px 14px;
    border-radius: 50px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(108, 92, 231, 0.2);
    animation: flashIndicator 1.5s infinite;
  }

  @keyframes flashIndicator {
    0% { opacity: 0.7; transform: scale(0.98); }
    50% { opacity: 1; transform: scale(1); }
    100% { opacity: 0.7; transform: scale(0.98); }
  }

  /* Viewport and Box */
  .scanner-box-wrapper {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 0 0 20px 20px;
    padding: 24px;
    box-shadow: 0 20px 25px -5px rgba(108, 92, 231, 0.04), 0 10px 10px -5px rgba(108, 92, 231, 0.02);
  }

  .scanner-box {
    width: 100%;
    height: 560px;
    background: radial-gradient(circle at center, #111827 0%, #030712 100%);
    background-image: radial-gradient(circle at center, rgba(108, 92, 231, 0.08) 0%, rgba(3, 7, 18, 0) 80%),
                      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 100% 100%, 24px 24px, 24px 24px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.8), 0 10px 30px rgba(0, 0, 0, 0.2);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scanner-box.scanning {
    border-color: rgba(108, 92, 231, 0.35);
    box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.85), 0 0 30px rgba(108, 92, 231, 0.2);
  }

  /* Viewfinder corner brackets for high tech styling */
  .scanner-box::before {
    content: '';
    position: absolute;
    top: 16px; left: 16px; right: 16px; bottom: 16px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    pointer-events: none;
    border-radius: 12px;
  }

  /* Corner tech decos */
  .scanner-box::after {
    content: '';
    position: absolute;
    top: 24px; left: 24px; width: 16px; height: 16px;
    border-top: 2px solid rgba(255, 255, 255, 0.25);
    border-left: 2px solid rgba(255, 255, 255, 0.25);
    pointer-events: none;
  }
  
  .scanner-box-wrapper {
    position: relative;
  }

  .scanner-box-wrapper::before {
    content: '';
    position: absolute;
    bottom: 40px; right: 40px; width: 16px; height: 16px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.25);
    border-right: 2px solid rgba(255, 255, 255, 0.25);
    pointer-events: none;
    z-index: 2;
  }

  /* Scan Laser Line */
  .scan-laser {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, transparent 5%, #00f2fe 20%, #6c5ce7 50%, #00f2fe 80%, transparent 95%);
    box-shadow: 0 0 15px rgba(0, 242, 254, 0.8), 0 0 30px rgba(108, 92, 231, 0.6);
    z-index: 5;
    animation: laserScan 3s infinite ease-in-out;
  }

  @keyframes laserScan {
    0% { top: 4%; }
    50% { top: 94%; }
    100% { top: 4%; }
  }

  /* Idle Uploader Prompt */
  .upload-prompt {
    text-align: center;
    color: rgba(255, 255, 255, 0.9);
    max-width: 420px;
    padding: 40px;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .upload-prompt:hover {
    border-color: rgba(108, 92, 231, 0.35);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .prompt-icon {
    font-size: 3.5rem;
    background: linear-gradient(135deg, #00f2fe 0%, #6c5ce7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 20px;
    opacity: 0.95;
    animation: pulseIcon 2.5s infinite ease-in-out;
  }

  @keyframes pulseIcon {
    0% { transform: scale(1); opacity: 0.85; filter: drop-shadow(0 0 0px rgba(108,92,231,0)); }
    50% { transform: scale(1.05); opacity: 1; filter: drop-shadow(0 0 8px rgba(108,92,231,0.3)); }
    100% { transform: scale(1); opacity: 0.85; filter: drop-shadow(0 0 0px rgba(108,92,231,0)); }
  }

  /* Document Mockups */
  .document-mockup {
    width: 86%;
    height: 86%;
    background: #ffffff;
    box-shadow: 0 25px 60px -15px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(0,0,0,0.05);
    border-radius: 12px;
    padding: 30px;
    position: relative;
    overflow-y: auto;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 0.75rem;
    color: #1e293b;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    animation: fadeInDoc 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Custom scrollbar for mockup document */
  .document-mockup::-webkit-scrollbar {
    width: 6px;
  }
  .document-mockup::-webkit-scrollbar-track {
    background: transparent;
  }
  .document-mockup::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 4px;
  }

  @keyframes fadeInDoc {
    from { opacity: 0; transform: scale(0.96) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* Payroll sheet specifics */
  .payroll-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 16px;
    margin-bottom: 16px;
  }

  .company-logo-mock {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #6c5ce7 0%, #a8a5e6 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 800;
    font-size: 1.1rem;
    box-shadow: 0 4px 8px rgba(108, 92, 231, 0.2);
  }
  .company-logo-mock::after {
    content: 'D';
  }

  .company-info-mock {
    font-size: 0.68rem;
    flex-grow: 1;
    margin-left: 14px;
    line-height: 1.4;
    color: #475569;
  }

  .payroll-title {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    padding: 8px 16px;
    border-radius: 6px;
    color: #0f172a;
  }

  .payroll-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 20px;
    background: #f8fafc;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid #f1f5f9;
  }

  .payroll-meta-grid div {
    color: #475569;
    font-size: 0.72rem;
  }

  .payroll-meta-grid div strong {
    color: #0f172a;
  }

  .payroll-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .payroll-table th {
    background: #f8fafc;
    color: #475569;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.5px;
    text-align: left;
    padding: 8px 10px;
    border-bottom: 2px solid #e2e8f0;
  }

  .payroll-table td {
    padding: 8px 10px;
    border-bottom: 1px solid #f1f5f9;
    font-size: 0.7rem;
    color: #334155;
  }

  .payroll-table tr.highlighted-row {
    background: rgba(108, 92, 231, 0.04);
    border-top: 1px solid rgba(108, 92, 231, 0.12);
    border-bottom: 1px solid rgba(108, 92, 231, 0.12);
  }

  .payroll-table tr.highlighted-row td {
    font-weight: 600;
    color: #0f172a;
  }

  .payroll-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    color: #94a3b8;
    border-top: 1px solid #e2e8f0;
    padding-top: 16px;
    margin-top: 16px;
  }

  .footer-sign {
    font-weight: 500;
  }

  .footer-stamp {
    background: rgba(16, 185, 129, 0.08);
    color: #10b981;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 700;
    border: 1px solid rgba(16, 185, 129, 0.15);
  }

  /* Tax sheet specifics */
  .tax-sheet {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .tax-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #0f172a;
    padding-bottom: 12px;
    margin-bottom: 20px;
    color: #0f172a;
  }

  .tax-header div:first-child {
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.5px;
