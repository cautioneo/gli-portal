  }

  @keyframes hotspotPulse {
    0% {
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6), 0 0 0 6px rgba(239, 68, 68, 0.2);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(239, 68, 68, 0), 0 0 0 16px rgba(239, 68, 68, 0);
    }
