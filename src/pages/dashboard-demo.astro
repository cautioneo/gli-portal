---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Espace Propriétaire (Démo) | Cautioneo Bailleurs";
const pageDescription = "Découvrez l'expérience zéro paperasse de l'Espace Bailleur Cautioneo. Suivez vos revenus garantis, analysez les dossiers locataires certifiés et gérez vos biens.";
const pageCanonical = "https://cautioneo-gli.com/dashboard-demo";
const pageNoindex = true;

const breadcrumbs = [
  { name: "Accueil", item: "https://cautioneo-gli.com/" },
  { name: "Démo Dashboard" }
];
const pageKeywords = "espace, gestion locative, propriétaire, (démo), dashboard demo";
