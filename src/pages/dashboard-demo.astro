<script is:inline>
        // Logique spécifique à la modale de démo
        function openDemoModal(e) {
            e.preventDefault();
            document.getElementById('demo-modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        function closeDemoModal() {
            document.getElementById('demo-modal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        document.addEventListener('DOMContentLoaded', () => {
            const tabOverview = document.getElementById('tab-overview');
            const tabCro = document.getElementById('tab-cro');
            const overviewContent = document.getElementById('overview-content');
            const croContent = document.getElementById('cro-analytics-content');

            if (tabOverview && tabCro && overviewContent && croContent) {
                // Tab switching
                tabOverview.addEventListener('click', (e) => {
                    e.preventDefault();
                    tabOverview.classList.add('active');
                    tabCro.classList.remove('active');
                    overviewContent.style.display = 'block';
                    croContent.style.display = 'none';
                });

                tabCro.addEventListener('click', (e) => {
                    e.preventDefault();
                    tabCro.classList.add('active');
                    tabOverview.classList.remove('active');
                    overviewContent.style.display = 'none';
                    croContent.style.display = 'block';
                    updateCroDashboard();
                });

                // CRO stats update function
                function updateCroDashboard() {
                    const stats = window.getCroStats ? window.getCroStats() : { impressions: 0, dismissals: 0, conversions: 0 };
                    
                    // Update KPI values
                    document.getElementById('cro-val-impressions').textContent = stats.impressions;
                    document.getElementById('cro-val-dismissals').textContent = stats.dismissals;
                    document.getElementById('cro-val-conversions').textContent = stats.conversions;
                    
                    const cr = stats.impressions > 0 ? ((stats.conversions / stats.impressions) * 100).toFixed(1) : "0.0";
                    document.getElementById('cro-val-cr').textContent = cr + " %";

                    // Update Funnel values
                    document.getElementById('funnel-val-impressions').textContent = stats.impressions;
                    document.getElementById('funnel-val-dismissals').textContent = stats.dismissals + " (" + (stats.impressions > 0 ? ((stats.dismissals / stats.impressions) * 100).toFixed(0) : "0") + "%)";
                    document.getElementById('funnel-val-conversions').textContent = stats.conversions + " (" + (stats.impressions > 0 ? ((stats.conversions / stats.impressions) * 100).toFixed(0) : "0") + "%)";

                    // Update Funnel Bars
                    document.getElementById('funnel-bar-impressions').style.width = stats.impressions > 0 ? "100%" : "0%";
                    document.getElementById('funnel-bar-dismissals').style.width = stats.impressions > 0 ? ((stats.dismissals / stats.impressions) * 100) + "%" : "0%";
                    document.getElementById('funnel-bar-conversions').style.width = stats.impressions > 0 ? ((stats.conversions / stats.impressions) * 100) + "%" : "0%";
                }

                // Helper function to save stats and update
                function saveStatsAndUpdate(stats) {
                    localStorage.setItem('cro_stats', JSON.stringify(stats));
                    updateCroDashboard();
                }

                // Simulators event listeners
                document.getElementById('btn-sim-impression').addEventListener('click', () => {
                    const stats = window.getCroStats ? window.getCroStats() : { impressions: 0, dismissals: 0, conversions: 0 };
                    stats.impressions++;
                    saveStatsAndUpdate(stats);
                });

                document.getElementById('btn-sim-dismiss').addEventListener('click', () => {
                    const stats = window.getCroStats ? window.getCroStats() : { impressions: 0, dismissals: 0, conversions: 0 };
                    if (stats.dismissals >= stats.impressions) {
                        stats.impressions++;
                    }
                    stats.dismissals++;
                    saveStatsAndUpdate(stats);
                });

                document.getElementById('btn-sim-conversion').addEventListener('click', () => {
                    const stats = window.getCroStats ? window.getCroStats() : { impressions: 0, dismissals: 0, conversions: 0 };
                    if (stats.conversions >= stats.impressions) {
                        stats.impressions++;
                    }
                    stats.conversions++;
                    saveStatsAndUpdate(stats);
                });

                document.getElementById('btn-reset-stats').addEventListener('click', () => {
                    if (confirm("Voulez-vous vraiment réinitialiser toutes les données de tracking CRO ?")) {
                        const emptyStats = { impressions: 0, dismissals: 0, conversions: 0 };
                        saveStatsAndUpdate(emptyStats);
                    }
                });
            }
        });
    </script>`} />

<style>
