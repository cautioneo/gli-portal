---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Simulateur Loyer Salaire : Calculez votre capacité locative | Cautioneo";
const pageDescription = "Simulateur gratuit : calculez le loyer maximum que vous pouvez payer avec votre salaire (règle des 33%), ou le revenu minimum exigé pour un loyer donné.";
const pageCanonical = "https://cautioneo-gli.com/simulateur-loyer-salaire";
const pageNoindex = false;
const aggregateRating = {
  ratingValue: 4.6,
  reviewCount: 715
};


const breadcrumbs = [
  { name: "Accueil", item: "https://cautioneo-gli.com/" },
  { name: "Simulateur Loyer & Salaire" }
];
---

<Layout title={pageTitle} description={pageDescription} canonical={pageCanonical} noindex={pageNoindex} breadcrumbs={breadcrumbs}
  aggregateRating={aggregateRating}>
  <Fragment set:html={`<header class="page-hero">
<div class="container">
<h1>Simulateur Loyer &amp; Salaire</h1>
<p class="opacity-90">Calculez instantanément votre capacité locative (règle des 33% d'endettement) ou le salaire minimum requis pour louer un appartement.</p>
</div>
</header>
<section class="section">
<div class="container">
<div class="simulator-box" data-reveal="fade-up">
<div class="tabs">
<button class="tab-btn active" onclick="switchTab('salaryToRent')">Je connais mon salaire</button>
<button class="tab-btn" onclick="switchTab('rentToSalary')">Je connais le loyer</button>
</div>
<!-- Tab 1: Salaire vers Loyer -->
<div id="salaryToRent">
<div class="input-group">
<label for="salaryInput">Salaire net mensuel avant impôt :</label>
<div class="input-wrapper">
<input id="salaryInput" oninput="calculateRent()" placeholder="Ex: 2500" type="number"/>
<span class="input-suffix">€</span>
</div>
</div>
<div class="result-box">
<p class="text-muted">Le loyer maximum estimé est de :</p>
<div class="result-amount" id="rentResult">0 €</div>
<p class="text-sm opacity-70 mt-8">Basé sur la règle standard des 33% de taux d'endettement.</p>
</div>
</div>
<!-- Tab 2: Loyer vers Salaire -->
<div id="rentToSalary" style="display: none;">
<div class="input-group">
<label for="rentInput">Loyer mensuel charges comprises (CC) :</label>
<div class="input-wrapper">
<input id="rentInput" oninput="calculateSalary()" placeholder="Ex: 800" type="number"/>
<span class="input-suffix">€</span>
</div>
</div>
<div class="result-box">
<p class="text-muted">Salaire net minimum exigé :</p>
<div class="result-amount" id="salaryResult">0 €</div>
<p class="text-sm opacity-70 mt-8">Revenu mensuel minimum pour qu'un dossier soit accepté par une assurance classique.</p>
</div>
</div>
<div class="text-center mt-32">
<h4 class="mb-12">Votre profil est un peu juste ?</h4>
<p class="text-muted mb-16">Si vos revenus sont inférieurs aux critères ou que vous n'avez pas de CDI, Cautioneo peut se porter garant pour vous.</p>
<a class="btn btn-primary border-radius-pill w-100" href="https://caut.io/Ffr6hkV" target="_blank" title="Souscrire à l'assurance loyer impayé Cautioneo">Certifier mon dossier locataire</a>
</div>
</div>
<div class="mt-64 max-w-800 mx-auto">
<h3 class="text-xl mb-16">Comment fonctionne ce calcul ?</h3>
<p class="text-muted mb-16">En France, la règle d'or pour louer un appartement est d'avoir des revenus nets mensuels équivalents à <strong>3 fois le montant du loyer</strong>. Cela correspond à un taux d'effort (ou taux d'endettement) de 33%.</p>
<p class="text-muted">Si le locataire gagne 2 400 € nets, il pourra prétendre à un loyer de 800 € maximum. Les propriétaires bailleurs et les assurances loyers impayés (GLI) appliquent strictement ce critère.</p>
</div>
</div>
</section>
<!-- Footer Partagé Riche -->


<script>
        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            if(tabId === 'salaryToRent') {
                document.getElementById('salaryToRent').style.display = 'block';
                document.getElementById('rentToSalary').style.display = 'none';
            } else {
                document.getElementById('salaryToRent').style.display = 'none';
                document.getElementById('rentToSalary').style.display = 'block';
            }
        }

        function calculateRent() {
            const salary = parseFloat(document.getElementById('salaryInput').value) || 0;
            const rent = Math.floor(salary / 3);
            document.getElementById('rentResult').innerText = rent + ' €';
        }

        function calculateSalary() {
            const rent = parseFloat(document.getElementById('rentInput').value) || 0;
            const salary = rent * 3;
            document.getElementById('salaryResult').innerText = salary + ' €';
        }
    </script>`} />
</Layout>
