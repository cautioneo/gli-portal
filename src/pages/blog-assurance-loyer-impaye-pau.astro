const pageCanonical = "https://cautioneo-gli.com/blog-assurance-loyer-impaye-pau";
const pageNoindex = false;
const aggregateRating = {
  ratingValue: 4.6,
  reviewCount: 715
};

const breadcrumbs = [
  { name: "Accueil", item: "https://cautioneo-gli.com/" },
  { name: "Blog", item: "https://cautioneo-gli.com/blog" },
  { name: pageTitle }
];

const faqItems = [
  {
    question: "Comment gerer un impaye a Pau ?",
    answer: "A Pau, le Tribunal Judiciaire de Pau (Tribunal Judiciaire de Pau_ADDR, 64000) est competent. La GLI Cautioneo indemnise des le premier impaye."
  },
  {
    question: "Pau est-elle une bonne ville pour investir ?",
    answer: "Oui. Pau beneficie d'un cadre de vie exceptionnel (vue sur les Pyrenees) et d'une economie diversifiee. Prix d'achat accessibles (1 600 a 2 400 EUR/m2). Rendements bruts : 6 a 8 %."
  },
  {
    question: "Les loyers sont-ils encadres a Pau ?",
    answer: "Non. Pau n'applique pas l'encadrement des loyers en 2026."
  },
  {
    question: "Quel est le delai d'expulsion a Pau ?",
    answer: "A Pau, la procedure d'expulsion dure 10 a 14 mois. La GLI Cautioneo vous indemnise sans delai des le 1er mois d'impaye."
  },
];
