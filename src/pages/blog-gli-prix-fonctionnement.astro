                });
            }
        })();

        // Interactive Simulator Logic
        (function() {
            const inputLoyer = document.getElementById('loyer-cc');
            const selectTmi = document.getElementById('tmi');
            const resPrime = document.getElementById('res-prime');
            const resEco = document.getElementById('res-economie');
            const resNet = document.getElementById('res-net');

            function updateCalculations() {
                const loyer = parseFloat(inputLoyer.value) || 0;
                const tmi = parseFloat(selectTmi.value) || 0;

                // Prime is 2.75% of rent
                const prime = loyer * 0.0275;
                // Tax savings = prime * (TMI + 17.2% social contributions)
                const eco = prime * (tmi + 0.172);
                const net = prime - eco;

                resPrime.textContent = prime.toFixed(2).replace('.', ',') + ' € / mois';
                resEco.textContent = '-' + eco.toFixed(2).replace('.', ',') + ' € / mois';
                resNet.textContent = net.toFixed(2).replace('.', ',') + ' € / mois';
            }

            if (inputLoyer && selectTmi) {
                inputLoyer.addEventListener('input', updateCalculations);
                selectTmi.addEventListener('change', updateCalculations);
                updateCalculations();
            }
        })();
    </script>
