<th class="table-accent">Cautioneo</th>
<th>Mila (Sécurité)</th>
<th>Mila (Sérénité)</th>
</tr>
</thead>
<tbody>
<tr>
<td class="font-600">Cotisation</td>
<td>Certifié</td>
