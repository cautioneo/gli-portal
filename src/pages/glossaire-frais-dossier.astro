<li><a href="/index#solvabilite">Testeur de Solvabilité</a></li>
<li><a href="/boite-a-outils">Boîte à Outils</a></li>
</ul>
</div>
<div class="footer-col">
<h4>Légal</h4>
<ul class="footer-links">
<li><a href="/mentions-legales">Mentions légales</a></li>
<li><a href="/cgs">CGS / CGU</a></li>
<li><a href="/confidentialite">Protection des données</a></li>
<li><a href="/reclamation">Réclamations</a></li>
<li><a href="/conciergerie">Conciergerie</a></li>
</ul>
</div>
</div>
