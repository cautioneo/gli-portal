---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Caution Solidaire en Location : Définition et Pièges";
const pageDescription = "Qu'est-ce qu'une caution solidaire ? Engagements du garant physique, clauses abusives, résiliation et alternatives de GLI.";
