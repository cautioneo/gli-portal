---
interface Props {
  title: string;
  description: string;
  canonical: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; item?: string }>;
  publishDate?: string;
  modifiedDate?: string;
  faqItems?: Array<{ question: string; answer: string }>;
  keywords?: string;
  aggregateRating?: {
    ratingValue: number;
    reviewCount: number;
    bestRating?: number;
  };
  image?: string;
  localBusiness?: {
    name: string;
    description: string;
    city: string;
    region: string;
    postalCode: string;
    telephone?: string;
  };
}

const { title, description, canonical, noindex = false, breadcrumbs, publishDate, modifiedDate, faqItems, keywords, aggregateRating, image, localBusiness } = Astro.props;
const canonicalUrl = new URL(canonical, Astro.site).href;
const isBlogPost = Astro.url.pathname.includes('/blog-') || Astro.url.pathname.includes('/guide-') || Astro.url.pathname.includes('/procedures') || Astro.url.pathname.includes('/fiscalite') || Astro.url.pathname.includes('/simulateur') || Astro.url.pathname.includes('/boite-a-outils') || Astro.url.pathname.includes('/checklist') || Astro.url.pathname.includes('/modeles') || Astro.url.pathname.includes('/mega-');
const defaultImage = "https://cautioneo-gli.com/logo.png";
const articleImage = image ? new URL(image, Astro.site).href : defaultImage;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>{title}</title>
    <meta name="description" content={description}/>
    {keywords && <meta name="keywords" content={keywords}/>}
    <link rel="canonical" href={canonicalUrl}/>
    <meta content={noindex ? "noindex, follow" : "index, follow"} name="robots"/>
    <meta content="Cautioneo" name="author"/>
    <meta content="Cautioneo" name="publisher"/>
    
    <!-- Open Graph / Facebook -->
    <meta content={isBlogPost ? "article" : "website"} property="og:type"/>
    <meta content={canonicalUrl} property="og:url"/>
    <meta content={title} property="og:title"/>
    <meta content={description} property="og:description"/>
    <meta content={articleImage} property="og:image"/>
    
    <!-- Twitter -->
    <meta content="summary_large_image" name="twitter:card"/>
    <meta content={canonicalUrl} name="twitter:url"/>
    <meta content={title} name="twitter:title"/>
    <meta content={description} name="twitter:description"/>
    <meta content={articleImage} name="twitter:image"/>


    <link rel="preload" href="/fonts/inter-v18-latin-400.woff2" as="font" type="font/woff2" crossorigin />
