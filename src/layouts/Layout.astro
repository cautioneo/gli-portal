    </noscript>
    
    {breadcrumbs && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((bc, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": bc.name,
          ...(bc.item ? { "item": bc.item } : {})
        }))
      })} />
    )}

    {faqItems && faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map(item => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer
          }
        }))
      })} />
    )}

    {isBlogPost && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "image": articleImage,
        "url": canonicalUrl,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl
        },
        "author": {
          "@type": "Organization",
          "name": "L'Equipe Cautioneo",
          "url": "https://cautioneo-gli.com"
        },
        "reviewedBy": {
          "@type": "Person",
          "name": "Jean-Pierre Dupin",
          "jobTitle": "Expert en Droit Immobilier & Gestion Locative",
          "url": "https://www.linkedin.com/in/jean-pierre-dupin-immobilier"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Cautioneo",
          "url": "https://cautioneo-gli.com",
          "logo": {
            "@type": "ImageObject",
            "url": "https://cautioneo-gli.com/logo.png"
          }
        },
        "datePublished": publishDate || "2026-05-26",
        "dateModified": modifiedDate || publishDate || "2026-06-15",
        "inLanguage": "fr-FR",
        "isPartOf": {
          "@type": "Blog",
          "name": "Blog Cautioneo - Conseils Propriétaires Bailleurs & GLI",
          "url": "https://cautioneo-gli.com/blog"
        }
      })} />
    )}

    {localBusiness && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "InsuranceAgency",
        "name": localBusiness.name,
        "description": localBusiness.description,
        "url": canonicalUrl,
        "image": "https://cautioneo-gli.com/logo.png",
        "telephone": localBusiness.telephone || "+33 9 72 10 40 40",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": localBusiness.city,
          "addressRegion": localBusiness.region,
          "postalCode": localBusiness.postalCode,
          "addressCountry": "FR"
        },
        "sameAs": [
          "https://share.google/1GIqfuIovN1OjliaE",
          "https://www.facebook.com/cautioneo",
          "https://www.linkedin.com/company/cautioneo"
        ]
      })} />
    )}

    {aggregateRating && (
