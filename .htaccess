# Apache Configuration for Pretty URLs
RewriteEngine On

# Ensure we use HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force trailing slash removal (Redirect /page/ to /page)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Redirect old B2B /blog/* URLs to flat /blog-* URLs
RewriteRule ^blog/(.+)$ /blog-$1 [R=301,L]

# Redirect /page.html to /page (External Redirect for SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.html\ HTTP/
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Serve /page as /page.html (Internal Rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Handle index.html specifically
DirectoryIndex index.html
